{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Shruggie Markdown",
  "version": "0.1.0",
  "identifier": "com.shruggietech.shruggie-md",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Shruggie Markdown",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https:; font-src 'self' data:;"
    }
  },
  "plugins": {
    "fs": {
      "scope": {
        "allow": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "template": null,
        "fragmentPaths": [],
        "componentGroupRefs": [],
        "featureGroupRefs": [],
        "fileAssociations": [
          {
            "ext": "md",
            "name": "Markdown File",
            "description": "Markdown document"
          },
          {
            "ext": "markdown",
            "name": "Markdown File",
            "description": "Markdown document"
          }
        ]
      }
    },
    "macOS": {
      "fileAssociations": [
        {
          "ext": ["md", "markdown"],
          "name": "Markdown File",
          "role": "Editor"
        }
      ]
    },
    "linux": {
      "desktop": {
        "categories": ["TextEditor", "Utility"],
        "mimeTypes": ["text/markdown"]
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  }
}

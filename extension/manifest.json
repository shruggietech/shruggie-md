{
  "manifest_version": 3,
  "name": "Shruggie Markdown",
  "version": "0.3.4",
  "description": "A beautiful markdown viewer and editor for Chrome",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["*://*/*"],
  "content_scripts": [
    {
      "matches": [
        "*://*/*.md",
        "*://*/*.markdown",
        "*://*/*.mdown",
        "*://*/*.mkdn",
        "*://*/*.mkd"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Shruggie Markdown"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}

{
  "name": "shruggie-md",
  "version": "0.3.6",
  "private": true,
  "type": "module",
  "description": "Cross-platform markdown viewer/editor/converter",
  "scripts": {
    "dev": "vite --port 1420",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "node scripts/clean-dist.js && tauri dev",
    "tauri:build": "node scripts/clean-dist.js && tauri build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "build:extension": "vite build --config vite.extension.config.ts && node scripts/copy-extension-assets.js"
  },
  "keywords": [],
  "author": "William Thompson <ShruggieTech>",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.28.2",
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.2",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/lint": "^6.9.5",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.40.0",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "codemirror": "^6.0.2",
    "dompurify": "^3.3.3",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.6.0",
    "markdown-it": "^14.1.1",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "markdownlint": "^0.40.0",
    "marked": "^17.0.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-html": "^16.0.1",
    "remark-preset-lint-recommended": "^7.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.38",
    "@types/dompurify": "^3.2.0",
    "@types/filesystem": "^0.0.36",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.1"
  }
}
